# ============================================
# LOCAL DEVELOPMENT (default - no changes needed)
# ============================================
DATABASE_URL="file:./dev.db"
JWT_SECRET="your-super-secret-key-change-this-in-production"

# ============================================
# PRODUCTION / CLOUD DEPLOYMENT (Turso)
# ============================================
# Get these from https://turso.tech dashboard after creating a database
# TURSO_DATABASE_URL="libsql://your-database-name-your-org.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# Generate a strong JWT secret for production:
# Run this in terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_SECRET="paste-the-generated-string-here"
